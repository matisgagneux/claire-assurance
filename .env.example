# ---- Base de données ----
# Utilisée par l'app Next.js (host) pour se connecter au Postgres exposé par Docker
DATABASE_URL="postgresql://claire:claire@localhost:5432/claire_assurance?schema=public"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
# Générez une vraie valeur avec: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me-please-0123456789abcdef"

# ---- Keycloak (provider OIDC) ----
KEYCLOAK_ISSUER="http://localhost:8080/realms/claire-assurance"
KEYCLOAK_CLIENT_ID="claire-backoffice"
KEYCLOAK_CLIENT_SECRET="claire-backoffice-secret"
